rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isSuperAdmin() {
      return isAuthenticated() && userRole() == 'super_admin';
    }

    function isAdminOrSuperAdmin() {
      return isAuthenticated() && userRole() in ['admin', 'super_admin'];
    }

    function userSabha() {
      return isAuthenticated()
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data.pradeshikaSabha
        : null;
    }

    // Authenticated user role may list only documents in their assigned Pradeshika Sabha.
    function isUserListingOwnSabha() {
      return isAuthenticated()
        && userRole() == 'user'
        && userSabha() != null
        && userSabha() != ''
        && resource.data.personalDetails.pradeshikaSabha == userSabha();
    }

    // Single-doc read by ID (shareable view/edit links); collection queries restricted below.
    match /member_details/{docId} {
      allow get, create, update: if true;
      allow list: if isAdminOrSuperAdmin() || isUserListingOwnSabha();
      allow delete: if isAdminOrSuperAdmin();
    }

    // User profiles: users can read/update their own document;
    // super_admin can read all and create/update/delete any user document
    match /users/{userId} {
      allow read: if isAuthenticated()
        && (request.auth.uid == userId || userRole() == 'super_admin');
      allow create, update: if isAuthenticated()
        && (request.auth.uid == userId || userRole() == 'super_admin');
      allow delete: if isSuperAdmin();
    }

    // Phone -> member ID mapping: get by phone (phone-check); create on registration;
    // list/delete for admin cleanup when member_details is removed
    match /member_ids/{phone} {
      allow get, create, update: if true;
      allow list, delete: if isAdminOrSuperAdmin();
    }

    // Admin contact numbers: anyone can read (shown on phone number lookup); only super_admin can write
    match /admin_contacts/{docId} {
      allow read: if true;
      allow write: if isSuperAdmin();
    }

    // Jilla membership statistics by year — admin/super_admin read (dashboard targets); super_admin write
    match /jilla_membership_details/{yearDoc} {
      allow read: if isAdminOrSuperAdmin();
      allow write: if isSuperAdmin();
    }

    // Backup & Sync Center — super_admin only
    match /sync_metadata/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /sync_failures/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /sync_history/{docId} {
      allow read, write: if isSuperAdmin();
    }

    // Restore Center — super_admin only
    match /restore_metadata/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /restore_history/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /restore_failures/{docId} {
      allow read, write: if isSuperAdmin();
    }

    match /restore_snapshots/{restoreJobId} {
      allow read, write: if isSuperAdmin();

      match /households/{recordId} {
        allow read, write: if isSuperAdmin();
      }
    }
  }
}

rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Member details: anyone can create/read/update (document ID acts as access token);
    // only admin can delete (enforced server-side via users collection)
    match /member_details/{docId} {
      allow create, read, update: if true;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // User profiles: users can read/update their own document;
    // super_admin can read all and create/update/delete any user document
    match /users/{userId} {
      allow read: if request.auth != null
        && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
      allow create, update: if request.auth != null
        && (request.auth.uid == userId
            || get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin');
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }

    // Phone -> member ID mapping: anyone can read (for phone-check page); anyone can create (on new record);
    // admin/super_admin can delete (when a member_details record is deleted)
    match /member_ids/{phone} {
      allow read, create, update: if true;
      allow delete: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role in ['admin', 'super_admin'];
    }

    // Admin contact numbers: anyone can read (shown on phone-check); only super_admin can write
    match /admin_contacts/{docId} {
      allow read: if true;
      allow write: if request.auth != null
        && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'super_admin';
    }
  }
}
